{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Command Completion Schema",
  "description": "Schema for command completion definitions in doge-shell",
  "required": ["command"],
  "properties": {
    "command": {
      "type": "string",
      "description": "The command name (e.g., 'git', 'docker', 'cargo')",
      "pattern": "^[^\\s]+$",
      "minLength": 1
    },
    "description": {
      "type": ["string", "null"],
      "description": "A brief description of the command"
    },
    "global_options": {
      "type": "array",
      "description": "Options that apply to the command globally",
      "items": {
        "$ref": "#/definitions/CommandOption"
      }
    },
    "options": {
      "type": "array",
      "description": "Legacy alias for global_options; the runtime loader merges these into global_options",
      "items": {
        "$ref": "#/definitions/CommandOption"
      }
    },
    "subcommands": {
      "type": "array",
      "description": "Subcommands of this command",
      "items": {
        "$ref": "#/definitions/SubCommand"
      }
    },
    "arguments": {
      "type": "array",
      "description": "Arguments accepted by the command itself",
      "items": {
        "$ref": "#/definitions/Argument"
      }
    }
  },
  "additionalProperties": false,
  "definitions": {
    "CommandOption": {
      "type": "object",
      "description": "Definition of a command line option",
      "properties": {
        "short": {
          "type": ["string", "null"],
          "description": "Short form of the option (e.g., '-v', '-f <FILE>', '-123'). Must start with one dash and not '--'.",
          "pattern": "^-(?!-)(?!\\s)\\S+(?:\\s+\\S.*)?$"
        },
        "long": {
          "type": ["string", "null"],
          "description": "Long or command-specific option form (e.g., '--verbose', '--type <TYPE>', '-Xmx', '+short'). Must start with '-' or '+' and must not be bare '-' or '--'.",
          "pattern": "^(?!--(?:\\s|$))[-+](?!\\s)\\S+(?:\\s+\\S.*)?$"
        },
        "description": {
          "type": ["string", "null"],
          "description": "Description of what the option does"
        },
        "takes_value": {
          "type": "boolean",
          "description": "Whether this option takes a value",
          "default": false
        },
        "required": {
          "type": "boolean",
          "description": "Whether this option is required",
          "default": false
        },
        "multiple": {
          "type": "boolean",
          "description": "Whether this option can be specified multiple times",
          "default": false
        },
        "value_type": {
          "$ref": "#/definitions/ArgumentType",
          "description": "Type of value this option takes"
        },
        "argument": {
          "$ref": "#/definitions/Argument",
          "description": "Argument definition for this option value"
        }
      },
      "oneOf": [
        {
          "required": ["short"]
        },
        {
          "required": ["long"]
        }
      ],
      "additionalProperties": false
    },
    "SubCommand": {
      "type": "object",
      "description": "Definition of a subcommand",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the subcommand",
          "minLength": 1,
          "pattern": "^[^\\s]+$"
        },
        "description": {
          "type": ["string", "null"],
          "description": "Description of what the subcommand does"
        },
        "aliases": {
          "type": "array",
          "description": "Alternative names for this subcommand",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "options": {
          "type": "array",
          "description": "Options specific to this subcommand",
          "items": {
            "$ref": "#/definitions/CommandOption"
          }
        },
        "arguments": {
          "type": "array",
          "description": "Arguments that this subcommand accepts",
          "items": {
            "$ref": "#/definitions/Argument"
          }
        },
        "subcommands": {
          "type": "array",
          "description": "Nested subcommands",
          "items": {
            "$ref": "#/definitions/SubCommand"
          }
        }
      },
      "additionalProperties": false
    },
    "Argument": {
      "type": "object",
      "description": "Definition of a command argument",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the argument",
          "minLength": 1
        },
        "description": {
          "type": ["string", "null"],
          "description": "Description of what the argument represents"
        },
        "required": {
          "type": "boolean",
          "description": "Whether this argument is required",
          "default": true
        },
        "multiple": {
          "type": "boolean",
          "description": "Whether multiple values can be provided for this argument",
          "default": false
        },
        "type": {
          "$ref": "#/definitions/ArgumentType",
          "description": "Type of value this argument expects"
        }
      },
      "additionalProperties": false
    },
    "ArgumentType": {
      "oneOf": [
        {
          "type": "object",
          "title": "File Type",
          "required": ["type"],
          "properties": {
            "type": {
              "type": "string",
              "enum": ["File"]
            },
            "data": {
              "type": "object",
              "properties": {
                "extensions": {
                  "type": ["array", "null"],
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        {
          "type": "object",
          "title": "Directory Type",
          "required": ["type"],
          "properties": {
            "type": {
              "type": "string",
              "enum": ["Directory"]
            }
          }
        },
        {
          "type": "object",
          "title": "String Type",
          "required": ["type"],
          "properties": {
            "type": {
              "type": "string",
              "enum": ["String"]
            }
          }
        },
        {
          "type": "object",
          "title": "Number Type",
          "required": ["type"],
          "properties": {
            "type": {
              "type": "string",
              "enum": ["Number"]
            }
          }
        },
        {
          "type": "object",
          "title": "Choice Type",
          "required": ["type", "data"],
          "properties": {
            "type": {
              "type": "string",
              "enum": ["Choice"]
            },
            "data": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        {
          "type": "object",
          "title": "Command Type",
          "required": ["type"],
          "properties": {
            "type": {
              "type": "string",
              "enum": ["Command"]
            }
          }
        },
        {
          "type": "object",
          "title": "Environment Type",
          "required": ["type"],
          "properties": {
            "type": {
              "type": "string",
              "enum": ["Environment"]
            }
          }
        },
        {
          "type": "object",
          "title": "URL Type",
          "required": ["type"],
          "properties": {
            "type": {
              "type": "string",
              "enum": ["Url"]
            }
          }
        },
        {
          "type": "object",
          "title": "Regex Type",
          "required": ["type"],
          "properties": {
            "type": {
              "type": "string",
              "enum": ["Regex"]
            }
          }
        },
        {
          "type": "object",
          "title": "Process Type",
          "required": ["type"],
          "properties": {
            "type": {
              "type": "string",
              "enum": ["Process"]
            }
          }
        },
        {
          "type": "object",
          "title": "Command With Args Type",
          "required": ["type"],
          "properties": {
            "type": {
              "type": "string",
              "enum": ["CommandWithArgs"]
            }
          }
        },
        {
          "type": "object",
          "title": "User Type",
          "required": ["type"],
          "properties": {
            "type": {
              "type": "string",
              "enum": ["User"]
            }
          }
        },
        {
          "type": "object",
          "title": "Group Type",
          "required": ["type"],
          "properties": {
            "type": {
              "type": "string",
              "enum": ["Group"]
            }
          }
        },
        {
          "type": "object",
          "title": "Signal Type",
          "required": ["type"],
          "properties": {
            "type": {
              "type": "string",
              "enum": ["Signal"]
            }
          }
        },
        {
          "type": "object",
          "title": "Interface Type",
          "required": ["type"],
          "properties": {
            "type": {
              "type": "string",
              "enum": ["Interface"]
            }
          }
        },
        {
          "type": "object",
          "title": "Dynamic Type",
          "required": ["type", "data"],
          "properties": {
            "type": {
              "type": "string",
              "enum": ["Dynamic"]
            },
            "data": {
              "type": "object",
              "required": ["provider"],
              "properties": {
                "provider": {
                  "type": "string",
                  "description": "Stable dynamic completion provider id",
                  "enum": [
                    "apt.installed_package",
                    "block.device",
                    "block.label",
                    "block.uuid",
                    "cargo.bin",
                    "cargo.example",
                    "cargo.package",
                    "dbus.service",
                    "dnf.installed_package",
                    "docker.compose_service",
                    "docker.container",
                    "docker.image",
                    "filesystem.type",
                    "fstab.mountpoint",
                    "git.branch",
                    "git.changed_path",
                    "git.checkout_target",
                    "git.push_branch",
                    "git.remote",
                    "git.remote_branch",
                    "git.revision",
                    "git.stash",
                    "git.tag",
                    "git.worktree",
                    "js.dependency",
                    "kernel.module",
                    "kubectl.context",
                    "kubectl.namespace",
                    "kubectl.resource_name",
                    "kubectl.resource_type",
                    "localectl.keymap",
                    "localectl.locale",
                    "loginctl.seat",
                    "loginctl.session",
                    "loop.device",
                    "mount.mountpoint",
                    "nmcli.connection",
                    "nmcli.device",
                    "pacman.package",
                    "pip.installed_package",
                    "project.task",
                    "rpm.installed_package",
                    "rustup.toolchain",
                    "screen.session",
                    "ssh.host",
                    "swap.device",
                    "sysctl.key",
                    "system.process_name",
                    "system.process_pid",
                    "systemctl.unit",
                    "systemctl.unit_file",
                    "timedatectl.timezone",
                    "tmux.session"
                  ]
                },
                "scope": {
                  "type": ["string", "null"],
                  "description": "Optional scope hint for the provider"
                }
              },
              "additionalProperties": false
            }
          }
        },
        {
          "type": "object",
          "title": "Script Type",
          "description": "Runtime-only manual completion type. comp-gen generated definitions must not emit Script.",
          "required": ["type", "data"],
          "properties": {
            "type": {
              "type": "string",
              "enum": ["Script"]
            },
            "data": {
              "type": "string",
              "description": "Shell command to execute for generating completions"
            }
          }
        }
      ]
    }
  }
}
