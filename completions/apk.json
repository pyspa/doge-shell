{
  "command": "apk",
  "description": "Alpine package manager",
  "global_options": [
    { "short": "-h", "long": "--help", "description": "Show help" },
    { "long": "--no-cache", "description": "Do not use local cache" },
    { "short": "-X", "long": "--repository", "description": "Use repository", "takes_value": true, "value_type": { "type": "Url" } }
  ],
  "subcommands": [
    { "name": "add", "description": "Add packages", "arguments": [{ "name": "package", "description": "Package name", "multiple": true, "type": { "type": "String" } }] },
    { "name": "del", "description": "Delete packages", "arguments": [{ "name": "package", "description": "Installed package", "multiple": true, "type": { "type": "Dynamic", "data": { "provider": "apk.installed_package" } } }] },
    { "name": "info", "description": "Show package information", "arguments": [{ "name": "package", "description": "Installed package", "multiple": true, "type": { "type": "Dynamic", "data": { "provider": "apk.installed_package" } } }] },
    { "name": "search", "description": "Search packages", "arguments": [{ "name": "pattern", "description": "Search pattern", "type": { "type": "String" } }] },
    { "name": "update", "description": "Update repository indexes" },
    { "name": "upgrade", "description": "Upgrade installed packages" },
    { "name": "fix", "description": "Repair installed packages", "arguments": [{ "name": "package", "description": "Installed package", "multiple": true, "type": { "type": "Dynamic", "data": { "provider": "apk.installed_package" } } }] },
    { "name": "cache", "description": "Manage package cache" }
  ]
}
