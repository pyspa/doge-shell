    {
      "description": "Print statistics",
      "short": "-s",
      "long": "--statistics"
    },
    {
      "description": "JSON output",
      "short": "-j",
      "long": "--json"
    },
    {
      "description": "Pretty JSON output",
      "short": "-p",
