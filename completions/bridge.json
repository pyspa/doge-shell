        {
          "name": "device",
          "description": "Network interface",
          "required": false,
          "type": {
            "type": "Interface"
          }
        }
      ]
    },
    {
      "name": "mdb",
      "description": "Multicast database commands",
      "arguments": [
        {
          "name": "device",
          "description": "Network interface",
          "required": false,
          "type": {
            "type": "Interface"
          }
        }
      ]
    },
    {
      "name": "vlan",
      "description": "VLAN filter commands",
      "arguments": [
        {
          "name": "device",
          "description": "Network interface",
          "required": false,
