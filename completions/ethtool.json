{
  "command": "ethtool",
  "description": "Query or control network driver and hardware settings",
  "global_options": [
    {
      "description": "Show driver information",
      "short": "-i",
      "long": "--driver"
    },
    {
      "description": "Show offload features",
      "short": "-k",
      "long": "--show-features"
    },
    {
      "description": "Show statistics",
      "short": "-S",
      "long": "--statistics"
    },
    {
      "description": "Change settings",
      "short": "-s",
      "long": "--change"
    },
    {
      "description": "Show ring parameters",
      "short": "-g",
      "long": "--show-ring"
    },
    {
      "description": "Change ring parameters",
      "short": "-G",
      "long": "--set-ring"
    },
    {
      "description": "Identify adapter by blinking LEDs",
      "short": "-p",
      "long": "--identify"
    },
    {
      "description": "Show pause parameters",
      "short": "-a",
      "long": "--show-pause"
    },
    {
      "description": "Change pause parameters",
      "short": "-A",
      "long": "--pause"
    },
    {
      "description": "Show channels",
      "short": "-l",
      "long": "--show-channels"
    },
    {
      "description": "Set channels",
      "short": "-L",
      "long": "--set-channels"
    }
  ],
  "arguments": [
    {
      "name": "interface",
      "description": "Network interface",
      "type": {
        "type": "Interface"
      }
    }
  ]
}
