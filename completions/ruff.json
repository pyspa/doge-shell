{
  "command": "ruff",
  "description": "Python linter and formatter",
  "global_options": [
    { "short": "-v", "long": "--verbose", "description": "Increase verbosity" },
    { "short": "-q", "long": "--quiet", "description": "Decrease verbosity" },
    { "long": "--config", "description": "Path to configuration file", "takes_value": true, "value_type": { "type": "File", "data": { "extensions": ["toml"] } } },
    { "short": "-h", "long": "--help", "description": "Show help" }
  ],
  "subcommands": [
    {
      "name": "check",
      "description": "Run Ruff linter",
      "options": [
        { "long": "--fix", "description": "Apply fixes" },
        { "long": "--unsafe-fixes", "description": "Apply unsafe fixes" },
        { "long": "--select", "description": "Rule codes to enable" },
        { "long": "--ignore", "description": "Rule codes to ignore" },
        { "long": "--fix-only", "description": "Apply fixes without reporting remaining violations" },
        { "long": "--output-format", "description": "Output format", "takes_value": true, "value_type": { "type": "Choice", "data": ["concise", "full", "json", "junit", "grouped", "github", "gitlab", "pylint", "rdjson", "azure"] } },
        { "long": "--watch", "description": "Run in watch mode" }
      ],
      "arguments": [{ "name": "path", "description": "File or directory", "required": false, "multiple": true, "type": { "type": "File", "data": {} } }]
    },
    {
      "name": "format",
      "description": "Run Ruff formatter",
      "options": [
        { "long": "--check", "description": "Do not write files" },
        { "long": "--diff", "description": "Print diff instead of writing files" }
      ],
      "arguments": [{ "name": "path", "description": "File or directory", "required": false, "multiple": true, "type": { "type": "File", "data": {} } }]
    },
    { "name": "rule", "description": "Explain a rule", "arguments": [{ "name": "rule", "description": "Rule code", "type": { "type": "String" } }] },
    { "name": "server", "description": "Run language server" },
    { "name": "config", "description": "List or describe configuration options" },
    { "name": "clean", "description": "Clear caches" }
  ]
}
