{
  "command": "top",
  "description": "Display and update sorted information about processes",
  "global_options": [
    {
      "short": "-h",
      "long": "--help",
      "description": "Display help information"
    },
    {
      "short": "-V",
      "long": "--version",
      "description": "Display version information"
    },
    {
      "short": "-p",
      "description": "Monitor only processes with given PIDs",
      "takes_value": true,
      "value_type": {
        "type": "Process"
      }
    },
    {
      "short": "-u",
      "description": "Show only processes for given user",
      "takes_value": true,
      "value_type": {
        "type": "User"
      }
    },
    {
      "short": "-n",
      "description": "Number of iterations before top exits",
      "takes_value": true,
      "value_type": {
        "type": "Number"
      }
    },
    {
      "short": "-d",
      "description": "Delay between updates in seconds",
      "takes_value": true,
      "value_type": {
        "type": "Number"
      }
    },
    {
      "short": "-b",
      "description": "Batch mode operation"
    },
    {
      "short": "-c",
      "description": "Display absolute path for command"
    },
    {
      "short": "-s",
      "description": "Secure mode"
    },
    {
      "short": "-o",
      "description": "Override sort field",
      "takes_value": true,
      "value_type": {
        "type": "Choice",
        "data": [
          "PID",
          "USER",
          "PR",
          "NI",
          "VIRT",
          "RES",
          "SHR",
          "S",
          "%CPU",
          "%MEM",
          "TIME+",
          "COMMAND"
        ]
      }
    }
  ],
  "subcommands": [],
  "arguments": []
}
