{
  "command": "ufw",
  "description": "Uncomplicated firewall command line tool",
  "subcommands": [
    {
      "name": "enable",
      "description": "Enable firewall"
    },
    {
      "name": "disable",
      "description": "Disable firewall"
    },
    {
      "name": "status",
      "description": "Show firewall status",
      "arguments": [
        {
          "name": "mode",
          "description": "Status detail",
          "type": {
            "type": "Choice",
            "data": [
              "verbose",
              "numbered"
            ]
          }
        }
      ]
    },
    {
      "name": "reload",
      "description": "Reload firewall"
    },
    {
      "name": "reset",
      "description": "Reset firewall"
    },
    {
      "name": "allow",
      "description": "Add allow rule",
      "arguments": [
        {
          "name": "rule",
          "description": "Rule specification",
          "multiple": true,
          "type": {
            "type": "String"
          }
        }
      ]
    },
    {
      "name": "deny",
      "description": "Add deny rule",
      "arguments": [
        {
          "name": "rule",
          "description": "Rule specification",
          "multiple": true,
          "type": {
            "type": "String"
          }
        }
      ]
    },
    {
      "name": "delete",
      "description": "Delete rule",
      "arguments": [
        {
          "name": "rule",
          "description": "Rule specification",
          "multiple": true,
          "type": {
            "type": "String"
          }
        }
      ]
    },
    {
      "name": "app",
      "description": "Manage application profiles",
      "subcommands": [
        {
          "name": "list",
          "description": "List application profiles"
        },
        {
          "name": "info",
          "description": "Show application profile information",
          "arguments": [
            {
              "name": "profile",
              "description": "Application profile",
              "type": {
                "type": "String"
              }
            }
          ]
        },
        {
          "name": "update",
          "description": "Update application profile rules"
        }
      ]
    }
  ]
}
