{
  "command": "direnv",
  "description": "Environment switcher for the shell",
  "global_options": [
    { "short": "-h", "long": "--help", "description": "Show help" },
    { "long": "--version", "description": "Show version" }
  ],
  "subcommands": [
    { "name": "allow", "description": "Allow loading .envrc", "arguments": [{ "name": "path", "description": "Directory", "required": false, "type": { "type": "Directory" } }] },
    { "name": "deny", "description": "Deny loading .envrc", "arguments": [{ "name": "path", "description": "Directory", "required": false, "type": { "type": "Directory" } }] },
    { "name": "edit", "description": "Edit .envrc", "arguments": [{ "name": "path", "description": "Directory", "required": false, "type": { "type": "Directory" } }] },
    { "name": "reload", "description": "Reload .envrc" },
    { "name": "status", "description": "Show direnv status" },
    { "name": "export", "description": "Export environment for shell", "arguments": [{ "name": "shell", "description": "Shell name", "type": { "type": "Choice", "data": ["bash", "zsh", "fish", "tcsh", "json"] } }] },
    { "name": "hook", "description": "Print shell hook", "arguments": [{ "name": "shell", "description": "Shell name", "type": { "type": "Choice", "data": ["bash", "zsh", "fish", "tcsh", "elvish"] } }] }
  ]
}
