{
  "command": "firewall-cmd",
  "description": "firewalld command line client",
  "global_options": [
    {
      "description": "Show help",
      "short": "-h",
      "long": "--help"
    },
    {
      "description": "Show version",
      "long": "--version"
    },
    {
      "description": "Permanent change",
      "long": "--permanent"
    },
    {
      "description": "Reload firewall",
      "long": "--reload"
    },
    {
      "description": "List all settings",
      "long": "--list-all"
    },
    {
      "description": "List services",
      "long": "--list-services"
    },
    {
      "description": "List ports",
      "long": "--list-ports"
    },
    {
      "description": "Get active zones",
      "long": "--get-active-zones"
    },
    {
      "description": "Get available zones",
      "long": "--get-zones"
    },
    {
      "description": "Get available services",
      "long": "--get-services"
    },
    {
      "description": "Get available ICMP types",
      "long": "--get-icmptypes"
    },
    {
      "description": "Zone name",
      "long": "--zone",
      "takes_value": true,
      "value_type": {
        "type": "Dynamic",
        "data": {
          "provider": "firewalld.zone"
        }
      }
    },
    {
      "description": "Add service",
      "long": "--add-service",
      "takes_value": true,
      "value_type": {
        "type": "Dynamic",
        "data": {
          "provider": "firewalld.service"
        }
      }
    },
    {
      "description": "Remove service",
      "long": "--remove-service",
      "takes_value": true,
      "value_type": {
        "type": "Dynamic",
        "data": {
          "provider": "firewalld.service"
        }
      }
    },
    {
      "description": "Add port",
      "long": "--add-port",
      "takes_value": true,
      "value_type": {
        "type": "String"
      }
    },
    {
      "description": "Remove port",
      "long": "--remove-port",
      "takes_value": true,
      "value_type": {
        "type": "String"
      }
    },
    {
      "description": "Add ICMP block",
      "long": "--add-icmp-block",
      "takes_value": true,
      "value_type": {
        "type": "Dynamic",
        "data": {
          "provider": "firewalld.icmp_type"
        }
      }
    },
    {
      "description": "Remove ICMP block",
      "long": "--remove-icmp-block",
      "takes_value": true,
      "value_type": {
        "type": "Dynamic",
        "data": {
          "provider": "firewalld.icmp_type"
        }
      }
    },
    {
      "description": "Add rich rule",
      "long": "--add-rich-rule",
      "takes_value": true,
      "value_type": {
        "type": "String"
      }
    },
    {
      "description": "Remove rich rule",
      "long": "--remove-rich-rule",
      "takes_value": true,
      "value_type": {
        "type": "String"
      }
    }
  ]
}
