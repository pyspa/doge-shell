{
  "command": "journalctl",
  "description": "Query the systemd journal",
  "global_options": [
    {
      "short": "-f",
      "long": "--follow",
      "description": "Show only the most recent journal entries, and continuously print new entries as they are appended to the journal"
    },
    {
      "short": "-e",
      "long": "--pager-end",
      "description": "Immediately jump to the end of the journal inside the implied pager tool"
    },
    {
      "short": "-b",
      "long": "--boot",
      "description": "Show messages from a specific boot",
      "takes_value": true,
      "value_type": {
        "type": "Dynamic",
        "data": {
          "provider": "journalctl.boot"
        }
      }
    },
    {
      "short": "-n",
      "long": "--lines",
      "description": "Show the most recent journal events, specified by the argument",
      "takes_value": true,
      "value_type": {
        "type": "Number"
      }
    },
    {
      "long": "--no-pager",
      "description": "Do not pipe output into a pager"
    },
    {
      "long": "--user",
      "description": "Show messages from user services"
    },
    {
      "long": "--system",
      "description": "Show messages from system services"
    },
    {
      "short": "-u",
      "long": "--unit",
      "description": "Show messages for the specified systemd unit",
      "takes_value": true,
      "value_type": {
        "type": "Dynamic",
        "data": {
          "provider": "systemctl.unit"
        }
      }
    },
    {
      "long": "--user-unit",
      "description": "Show messages for the specified user unit",
      "takes_value": true,
      "value_type": {
        "type": "Dynamic",
        "data": {
          "provider": "systemctl.unit"
        }
      }
    },
    {
      "short": "-S",
      "long": "--since",
      "description": "Start showing entries on or newer than the specified date",
      "takes_value": true,
      "value_type": {
        "type": "String"
      }
    },
    {
      "short": "-U",
      "long": "--until",
      "description": "Start showing entries on or older than the specified date",
      "takes_value": true,
      "value_type": {
        "type": "String"
      }
    },
    {
      "short": "-k",
      "long": "--dmesg",
      "description": "Show only kernel messages"
    },
    {
      "short": "-o",
      "long": "--output",
      "description": "Change journal output format",
      "takes_value": true,
      "value_type": {
        "type": "Choice",
        "data": [
          "short",
          "short-iso",
          "short-precise",
          "short-monotonic",
          "verbose",
          "export",
          "json",
          "json-pretty",
          "cat"
        ]
      }
    },
    {
      "short": "-p",
      "long": "--priority",
      "description": "Filter by priority",
      "takes_value": true,
      "value_type": {
        "type": "Choice",
        "data": [
          "emerg",
          "alert",
          "crit",
          "err",
          "warning",
          "notice",
          "info",
          "debug",
          "0",
          "1",
          "2",
          "3",
          "4",
          "5",
          "6",
          "7"
        ]
      }
    }
  ],
  "subcommands": []
}
