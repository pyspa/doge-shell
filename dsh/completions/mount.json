{
  "command": "mount",
  "description": "Mount a filesystem",
  "global_options": [
    {
      "short": "-h",
      "long": "--help",
      "description": "Display help"
    },
    {
      "short": "-V",
      "long": "--version",
      "description": "Display version"
    },
    {
      "short": "-a",
      "long": "--all",
      "description": "Mount all filesystems mentioned in fstab"
    },
    {
      "short": "-f",
      "long": "--fake",
      "description": "Dry run; print what would be done"
    },
    {
      "short": "-o",
      "long": "--options",
      "description": "Comma-separated list of mount options",
      "takes_value": true,
      "value_type": {
        "type": "String"
      }
    },
    {
      "short": "-r",
      "long": "--read-only",
      "description": "Mount the filesystem read-only"
    },
    {
      "short": "-w",
      "long": "--rw",
      "description": "Mount the filesystem read-write (default)"
    },
    {
      "short": "-t",
      "long": "--types",
      "description": "Limit the set of filesystem types",
      "takes_value": true,
      "value_type": {
        "type": "Dynamic",
        "data": {
          "provider": "filesystem.type"
        }
      }
    },
    {
      "short": "-v",
      "long": "--verbose",
      "description": "Verbose mode"
    }
  ],
  "arguments": [
    {
      "name": "device_or_mountpoint",
      "description": "Block device or fstab mount point",
      "type": {
        "type": "Dynamic",
        "data": {
          "provider": "block.device"
        }
      }
    },
    {
      "name": "mountpoint",
      "description": "Mount point directory",
      "type": {
        "type": "Directory"
      }
    }
  ],
  "subcommands": []
}
