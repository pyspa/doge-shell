{
  "command": "poetry",
  "description": "Python dependency and packaging manager",
  "global_options": [
    { "short": "-q", "long": "--quiet", "description": "Do not output messages" },
    { "short": "-v", "long": "--verbose", "description": "Increase verbosity" },
    { "short": "-C", "long": "--directory", "description": "Working directory", "takes_value": true, "value_type": { "type": "Directory" } },
    { "short": "-h", "long": "--help", "description": "Show help" }
  ],
  "subcommands": [
    { "name": "install", "description": "Install project dependencies" },
    { "name": "update", "description": "Update dependencies" },
    { "name": "lock", "description": "Lock dependencies" },
    {
      "name": "add",
      "description": "Add dependency",
      "options": [
        { "short": "-G", "long": "--group", "description": "Dependency group", "takes_value": true, "value_type": { "type": "String" } },
        { "short": "-D", "long": "--dev", "description": "Add as development dependency" },
        { "short": "-E", "long": "--extras", "description": "Extras to activate", "takes_value": true, "value_type": { "type": "String" } }
      ],
      "arguments": [{ "name": "package", "description": "Package requirement", "multiple": true }]
    },
    {
      "name": "remove",
      "description": "Remove dependency",
      "options": [
        { "short": "-G", "long": "--group", "description": "Dependency group", "takes_value": true, "value_type": { "type": "String" } },
        { "short": "-D", "long": "--dev", "description": "Remove from development dependencies" }
      ],
      "arguments": [
        { "name": "package", "description": "Package name", "multiple": true, "type": { "type": "Dynamic", "data": { "provider": "python.project_dependency" } } }
      ]
    },
    { "name": "run", "description": "Run a command in the virtualenv", "arguments": [{ "name": "command", "description": "Command to run", "type": { "type": "Command" } }] },
    { "name": "shell", "description": "Spawn a shell in the virtualenv" },
    {
      "name": "env",
      "description": "Manage virtual environments",
      "subcommands": [
        { "name": "info", "description": "Display environment info" },
        { "name": "list", "description": "List environments" },
        { "name": "use", "description": "Use a Python executable", "arguments": [{ "name": "python", "description": "Python executable", "type": { "type": "Command" } }] },
        { "name": "remove", "description": "Remove an environment" }
      ]
    },
    { "name": "show", "description": "Show information about packages", "arguments": [{ "name": "package", "description": "Dependency", "type": { "type": "Dynamic", "data": { "provider": "python.project_dependency" } } }] },
    { "name": "build", "description": "Build package" },
    { "name": "publish", "description": "Publish package" }
  ]
}
