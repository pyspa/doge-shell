{
  "command": "swapon",
  "description": "Enable devices and files for paging and swapping",
  "global_options": [
    {
      "short": "-a",
      "long": "--all",
      "description": "Enable all swaps from fstab"
    },
    {
      "short": "-s",
      "long": "--summary",
      "description": "Display swap summary"
    },
    {
      "long": "--show",
      "description": "Display swap areas"
    },
    {
      "short": "-p",
      "long": "--priority",
      "description": "Swap priority",
      "takes_value": true,
      "value_type": {
        "type": "Number"
      }
    },
    {
      "short": "-v",
      "long": "--verbose",
      "description": "Verbose output"
    }
  ],
  "arguments": [
    {
      "name": "device",
      "description": "Swap block device",
      "multiple": true,
      "type": {
        "type": "Dynamic",
        "data": {
          "provider": "block.device"
        }
      }
    }
  ]
}
